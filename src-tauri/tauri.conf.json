{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pomodoro Study",
  "version": "0.3.0",
  "identifier": "study.pomodoro.app",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Pomodoro Study",
        "width": 960,
        "height": 720,
        "minWidth": 720,
        "minHeight": 560,
        "decorations": true,
        "resizable": true,
        "transparent": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["assets/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  }
}
